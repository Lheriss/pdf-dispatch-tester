# pdf-dispatch-tester — configuration
# Copy this file to config.yaml and fill in your values.
# config.yaml is listed in .gitignore and will never be committed.

# ── Target instance ───────────────────────────────────────────────────────────
server:  "http://your-nas-ip:5881"
api_key: "pdf-dispatch-test-key"

# ── Filesystem access (Phase 1 — core processing tests) ──────────────────────
# Path to the pdf-dispatch /data directory, accessible from where the tester runs.
#
# Option A — tester runs as a container on the same NAS:
#   mount DATA_VOLUME_TEST:/data in both containers → data_path: "/data"
#
# Option B — tester runs directly on the NAS (SSH, no container):
#   data_path: "/volume1/docker/pdf-dispatch-test/data"
#
# Option C — tester runs on your Mac (no direct filesystem access):
#   data_path: ""   ← Phase 1 filesystem tests will be skipped
#
data_path: "/data"

# ── Email ingestion tests (Phase 4 — optional) ───────────────────────────────
smtp:
  host:     "smtp.gmail.com"
  port:     587
  user:     "pdf-dispatch-test@gmail.com"
  password: "your-app-password"

imap:
  host:     "imap.gmail.com"
  port:     993
  user:     "pdf-dispatch-test@gmail.com"
  password: "your-app-password"
  folder:   "INBOX"
